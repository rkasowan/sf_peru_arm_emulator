# ServiceNow instance + credentials
SN_INSTANCE_URL=https://your-instance.service-now.com
SN_USERNAME=your_integration_user
SN_PASSWORD=your_password
SN_VERIFY_SSL=true
SN_REQUEST_TIMEOUT_SECONDS=30

# Optional outbound proxy
# The installer, local helper scripts, Python requests, and curl sender will
# all honor these when set.
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1

# Polling behavior
POLL_INTERVAL_SECONDS=3
QUERY_OVERLAP_SECONDS=45
INITIAL_LOOKBACK_SECONDS=3600
ALERT_QUERY_LIMIT=100
ALERT_BOOTSTRAP_LIMIT=25
ALERT_DISCOVERY_HYDRATE_LIMIT=25
LOG_LEVEL=INFO
STATE_FILE=/var/lib/sf-peru-incident-management-process/state.json

# ARM filter being emulated
# Salesforce still posts straight to genericJsonV2. In stock behavior that often
# means source=GenericJSON, but the process also falls back to payload-shape
# matching on the alert / related event records instead of relying only on source
# and type.
ALERT_SOURCE=GenericJSON
ALERT_TYPE_CONTAINS=Amazon,peru
ALERT_QUERY_EXTRA=
ALERT_OPEN_STATE_TOKENS=open,reopen,reopened,new,active
ALERT_CLOSED_STATE_TOKENS=closed,resolved,clear,cleared

# DTI / Generic Endpoint push connector
# IMPORTANT:
# - Use the exact URL parameter value configured on your connector record.
# - Your production screenshot showed: source=genericJsonV2
# - Your production screenshot also showed a required header:
#     user-agent: genericendpoint
PUSH_CONNECTOR_URL=https://your-instance.service-now.com/api/sn_em_connector/em/inbound_event?source=genericJsonV2
PUSH_CONNECTOR_METHOD=POST
PUSH_CONNECTOR_HEADER_NAME=user-agent
PUSH_CONNECTOR_HEADER_VALUE=genericendpoint
PUSH_CONNECTOR_USERNAME=
PUSH_CONNECTOR_PASSWORD=
PUSH_CONNECTOR_BEARER_TOKEN=
PUSH_CONNECTOR_TIMEOUT_SECONDS=90
PUSH_CONNECTOR_PAYLOAD_MODE=single_event
PUSH_CONNECTOR_WAIT_SECONDS=30
PUSH_CONNECTOR_WAIT_POLL_SECONDS=2

# Historical bridge settings from an earlier experiment.
# Not required for the final production workaround.
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_PORT=8090
WEBHOOK_PATH=/salesforce/peru
WEBHOOK_AUTH_TOKEN=
WEBHOOK_EVENT_SOURCE=salesforce
WEBHOOK_EVENT_TYPE=Amazon
WEBHOOK_EVENT_CLASS=salesforce
WEBHOOK_METRIC_NAME=salesforce_case

# Extracted from your screenshots
PINC_TAG_SYS_ID=613dec0ffb0c4f9805e4f07555efdcd7
DEFAULT_CMDB_CI_SYS_ID=e69250481bbc59501582ed77b04bcbf6
DEFAULT_CMDB_CI_NAME=ServiceNow - Event Management
SALESFORCE_USER_SYS_ID=81abde4d1ba681905d48646b234bcbe8

# Incident enrichment after DTI creates the incident
INCIDENT_EXTERNAL_CASE_FIELD=u_external_salesforce_case_id
INCIDENT_GENERATING_ALERT_FIELD=u_generating_alert
SALESFORCE_OFFERING_SERVICE_NAME=Salesforce PERU Services
AUTO_CREATE_SERVICE_OFFERINGS=false
SET_ASSIGNED_TO=true
SET_CALLER_ID=true
ENABLE_TAGGING=true
ENABLE_CI_LOOKUP=true
# Optional dummy-group fallback if the chosen service offering has no support/L2/L3 group.
DEFAULT_ASSIGNMENT_GROUP_SYS_ID=

# Optional extra static incident fields applied after creation.
# Example:
# INCIDENT_EXTRA_STATIC_FIELDS_JSON={"contact_type":"monitoring"}
INCIDENT_EXTRA_STATIC_FIELDS_JSON=

# Dry run toggle for first validation
DRY_RUN=false
